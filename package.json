{
  "name": "outcome-liquidity-exchange",
  "version": "0.1.0",
  "private": true,
  "description": "Outcome Liquidity Exchange V1 modular monolith baseline",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "node --watch -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/main.js",
    "web:dev": "pnpm --filter ./apps/web dev",
    "web:lint": "pnpm --filter ./apps/web lint",
    "web:test": "pnpm --filter ./apps/web test",
    "web:build": "pnpm --filter ./apps/web build",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "validate": "pnpm run lint && pnpm run build && pnpm run test && pnpm run test:e2e && pnpm run web:lint && pnpm run web:test && pnpm run web:build",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "pnpm run typeorm -- migration:run -d src/database/data-source.ts",
    "migration:revert": "pnpm run typeorm -- migration:revert -d src/database/data-source.ts",
    "migration:generate": "pnpm run typeorm -- migration:generate -d src/database/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register src/database/seeds/seed.ts"
  },
  "dependencies": {
    "bullmq": "^5.76.6",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "joi": "^18.2.1",
    "ioredis": "^5.10.1",
    "ms": "^2.1.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.29"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/ms": "^2.1.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "overrides": {
    "glob": "^13.0.6"
  }
}
